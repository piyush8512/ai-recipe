# AI Recipe Mobile — Environment Variables

# Strapi Backend
EXPO_PUBLIC_STRAPI_URL=http://localhost:1337
EXPO_PUBLIC_STRAPI_API_TOKEN=your_strapi_api_token_here

# Google Gemini AI
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Unsplash (for recipe images)
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# MealDB Public API
EXPO_PUBLIC_MEALDB_BASE=https://www.themealdb.com/api/json/v1/1

# Clerk Auth
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
EXPO_PUBLIC_CLERK_BILLING_URL=https://your-domain.clerk.accounts.dev/user


NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up


ARCJET_KEY=


NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=

MEALDB_BASE=https://www.themealdb.com/api/json/v1/1

GEMINI_API_KEY

UNSPLASH_ACCESS_KEY
